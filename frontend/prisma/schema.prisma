generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DehazeJob {
  id                     String   @id @default(cuid())
  filename               String
  hazyImageUrl           String
  transmissionMapUrl     String
  dehazedImageUrl        String
  psnr                   Float
  ssim                   Float
  mae                    Float
  rmse                   Float
  processingTimeSeconds  Float
  benchmarked            Boolean  @default(true)
  createdAt              DateTime @default(now())

  @@index([createdAt])
}
